# Fig & Flour — Environment Variables
# Copy this file to .env and fill in the values.
# Prefix all public variables with VITE_ for Vite to expose them.

# --- Reservation API ---
# Base URL of the reservation backend (e.g. "https://api.figandflour.com")
VITE_API_BASE_URL=

# API key for reservation endpoints
VITE_API_KEY=

# Reservation endpoint path (default: "/api/reservations")
VITE_RESERVATIONS_ENDPOINT=

# --- Contact / Map ---
# Google Maps API key (if replacing Leaflet with Google Maps later)
# VITE_GOOGLE_MAPS_KEY=

# --- Feature Flags ---
# Toggle mock/demo mode (true = use local mock, false = hit real API)
VITE_DEMO_MODE=true
